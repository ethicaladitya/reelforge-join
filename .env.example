# ─── ReelForge Environment Config ───────────────────────────────────────────
# Copy this file to .env and fill in your values, then run: ./setup.sh start

# ── Google OAuth (required for login + YouTube publishing) ───────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Type: Web application
# Authorized redirect URIs:
#   https://YOUR_DOMAIN/auth/google/callback
#   https://YOUR_DOMAIN/api/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Public URL (required when behind Cloudflare Tunnel or any reverse proxy) ─
# Must match the domain in your authorized redirect URIs above
PUBLIC_URL=https://reel.adityashah.blog

# ── Instagram Publishing (optional) ─────────────────────────────────────────
# developers.facebook.com → Create App → Business → Instagram Graph API product
# Settings → Basic → copy App ID and Secret
# Valid OAuth redirect URI to add: https://YOUR_DOMAIN/api/auth/instagram/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Server config (optional, defaults shown) ─────────────────────────────────
HOST=127.0.0.1
PORT=7433

# ── Cloudflare Tunnel (optional, set tunnel name if using cloudflared) ────────
CF_TUNNEL_NAME=reelforge
